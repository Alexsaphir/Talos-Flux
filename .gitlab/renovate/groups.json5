{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  packageRules: [
    {
      description: 'Flux Operator Group',
      groupName: 'flux-operator',
      matchDatasources: ['docker'],
      matchPackageNames: ['/flux-operator/', '/flux-instance/'],
      group: {
        commitMessageTopic: '{{{groupName}}} group',
      },
      minimumGroupSize: 2,
    },
    {
      description: 'Rook-Ceph Group',
      groupName: 'rook-ceph',
      matchDatasources: ['docker'],
      matchPackageNames: ['/rook-ceph/', '/rook-ceph-cluster/'],
      group: {
        commitMessageTopic: '{{{groupName}}} group',
      },
      minimumGroupSize: 2,
    },
    {
      description: 'Dragonfly Operator Group',
      groupName: 'DragonflyOperator',
      matchPackagePatterns: [
        'docker.dragonflydb.io/dragonflydb/operator',
        'dragonflydb/dragonfly-operator',
      ],
      group: {
        commitMessageTopic: '{{{groupName}}} group',
      },
      separateMinorPatch: false,
    },
    {
      description: 'Immich Group',
      groupName: 'Immich',
      matchPackagePatterns: ['immich'],
      matchDatasources: ['docker', 'github-releases', 'helm'],
      matchUpdateTypes: ['minor', 'patch'],
      group: {
        commitMessageTopic: '{{{groupName}}} group',
      },
      separateMinorPatch: false,
    },

    {
      description: 'Codecov Group',
      groupName: 'Codecov',
      matchPackagePatterns: ['codecov'],
      matchDatasources: ['docker', 'github-releases'],
      group: {
        commitMessageTopic: '{{{groupName}}} group',
      },
      separateMinorPatch: true,
    },
    {
      description: 'Pre-Commit',
      groupName: 'Pre-Commit',
      matchManagers: ['pre-commit'],
    },
    {
      description: 'Aquaproj/aqua group',
      groupName: 'Aqua',
      matchFileNames: ['**/aqua.yaml', '**/.aqua.yaml', '**/.devcontainer.json'],
    },
    {
      description: 'YourSpotify Group',
      groupName: 'YourSpotify',
      matchDatasources: ['docker'],
      matchPackageNames: ['ghcr.io/yooooomi/your_spotify_*'],
    },
    {
      description: 'Slinky Group',
      groupName: 'Slinky',
      matchDatasources: ['docker'],
      matchPackageNames: ['/slinkyproject/'],
      group: {
        commitMessageTopic: '{{{groupName}}} group',
      },
      minimumGroupSize: 2,
    },
    {
      description: 'Toolhive Group',
      groupName: 'Toolhive',
      matchDatasources: ['docker'],
      matchPackageNames: ['/toolhive-operator/'],
      group: {
        commitMessageTopic: '{{{groupName}}} group',
      },
      minimumGroupSize: 2,
    },
    {
      description: 'Toolhive Group',
      groupName: 'Toolhive',
      matchDatasources: ['docker'],
      matchPackageNames: ['/toolhive-operator/'],
      group: {
        commitMessageTopic: '{{{groupName}}} group',
      },
      minimumGroupSize: 2,
    },
    {
      description: 'timescaledb Group',
      groupName: 'timescaledb',
      matchDatasources: ['docker'],
      matchPackageNames: ['/vember31\/timescaledb/'],
      group: {
        commitMessageTopic: '{{{groupName}}} group',
      },
      minimumGroupSize: 2,
    },
  ],
}
