{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'github>home-operations/renovate-presets#1.3.1',
    'github>aquaproj/aqua-renovate-config#2.12.1',
    'local>Homelab/Talos-Flux//.gitlab/renovate/groups.json5',
    'local>Homelab/Talos-Flux//.gitlab/renovate/labels.json5',
    'local>Homelab/Talos-Flux//.gitlab/renovate/packageRules.json5',
    'local>Homelab/Talos-Flux//.gitlab/renovate/automerge.json5',
    ':enablePreCommit',
    'security:openssf-scorecard',
    ':timezone(Europe/Paris)',
  ],
  dependencyDashboard: true,
  prConcurrentLimit: 3,
  configWarningReuseIssue: true,
  configMigration: true,
  gitLabIgnoreApprovals: true,
  suppressNotifications: [
    'prEditedNotification',
    'prIgnoreNotification',
  ],
  rebaseWhen: 'behind-base-branch',
}
